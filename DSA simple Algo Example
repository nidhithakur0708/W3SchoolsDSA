//Find the nth Fibonacii number
// Note: This formula uses a 0-based index. This means that to generate the 20th Fibonacci number, we must write F(19)
.
int fibo(int n){
    if(n<=1){
        return n;
    } else{
        return fibo(n-1)+fibo(n-2);
    }
}
 
int main(){
    int n;
    cout<<"Enter n:"<<endl;
    cin>>n;
    cout<<fibo(n);
}

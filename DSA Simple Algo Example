// Find the lowest value in the array
#include <bits/stdc++.h>
using namespace std;
 
int findLowest(int arr[],int n){
    int min_value=arr[0];
    for(int i=0;i<n;i++){
        if(arr[i]<min_value){
            min_value=arr[i];
        }
    }
    return min_value;
}
 
int main() {
    int n=5;
    int arr[n];
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    cout<<findLowest(arr,n);
    return 0;
}

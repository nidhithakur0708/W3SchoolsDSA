//Circular Singly Linked List
#include<bits/stdc++.h>
using namespace std;
 
class Node{
    public:
        int data;
        Node* next;
    Node(int val){
        data=val;
        next=nullptr;
    }
};
int main(){
    Node* node1=new Node(10);
    Node* node2=new Node(20);
    Node* node3=new Node(30);
    node1->next=node2;
    node2->next=node3;
    node3->next=node1;
    Node* temp=node1;
    do{
        cout<<temp->data<<"->";
        temp=temp->next;
    }while(temp!=node1);
